{
  "$schema": "https://github.com/Azure/data-api-builder/releases/latest/download/dab.draft.schema.json",
  "data-source": {
    "database-type": "mssql",
    "connection-string": "Server=tcp:<your-server>.msit-database.fabric.microsoft.com,1433;Initial Catalog=<your-database>;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;Authentication=Active Directory Default"
  },
  "runtime": {
    "rest": {
      "enabled": true,
      "path": "/api"
    },
    "graphql": {
      "enabled": false,
      "path": "/graphql"
    },
    "mcp": {
      "enabled": false
    },
    "host": {
      "mode": "development",
      "cors": {
        "origins": [
          "*"
        ]
      }
    }
  },
  "entities": {
    "authors": {
      "source": {
        "type": "table",
        "object": "dbo.authors"
      },
      "permissions": [
        {
          "role": "anonymous",
          "actions": [
            "read"
          ]
        }
      ]
    }
  }
}

